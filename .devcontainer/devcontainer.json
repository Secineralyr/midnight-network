{
  "name": "midnight-network",
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "false",
      "username": "vscode",
      "upgradePackages": "true"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "pnpm": "true",
      "nodeGypDependencies": "true",
      "installYarnUsingApt": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["svelte.svelte-vscode", "ardenivanov.svelte-intellisense", "biomejs.biome", "prisma.prisma"],
      "settings": {
        "biome.configurationPath": "./biome.json",
        "editor.codeActionsOnSave": {
          "source.fixAll.biome": "explicit",
          "source.organizeImports.biome": "explicit"
        },
        "editor.defaultFormatter": "biomejs.biome",
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[svelte]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[prisma]": {
          "editor.defaultFormatter": "Prisma.prisma"
        }
      }
    }
  },
  "postCreateCommand": "corepack enable && pnpm install && pnpm approve-builds",
  "forwardPorts": [5173, 8787],
  "appPort": [5173, 8787],
  "portsAttributes": {
    "5173": {
      "label": "main port (frontend/backend)"
    },
    "8787": {
      "label": "backend (Wrangler dev)"
    }
  },
  "remoteUser": "vscode"
}
