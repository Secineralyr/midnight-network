{
  "name": "midnight-network",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "check": "biome check .",
    "check:write": "biome check --write .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "front:dev": "pnpm --filter @midnight-network/frontend dev",
    "back:dev": "pnpm --filter @midnight-network/backend dev",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "catalog:",
    "@biomejs/biome": "catalog:"
  }
}
