// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

datasource db {
  provider = "sqlite"
}

model Record {
  id          Int       @id @default(autoincrement())
  noteId      String    @unique
  postedAt    DateTime
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  place       Int
  matchDateId Int
  matchDate   MatchDate @relation(fields: [matchDateId], references: [id])
  // meta
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EventMatch {
  id         Int         @id @default(autoincrement())
  multiplePt Float       @default(1.0)
  startDate  DateTime
  endDate    DateTime
  matchDates MatchDate[]
  // meta
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model MatchDate {
  id                Int               @id @default(autoincrement())
  date              DateTime          @unique
  eventId           Int?
  event             EventMatch?       @relation(fields: [eventId], references: [id])
  records           Record[]
  userRankHistories UserRankHistory[]
}

model UserRankStatus {
  id                    String   @id
  user                  User     @relation(fields: [id], references: [id])
  pt                    Int      @default(0)
  streakParticipationAt Int      @default(0)
  streakAbsenceAt       Int      @default(0)
  streakWithinTopAt     Int      @default(0)
  streakFlyingAt        Int      @default(0)
  protectCoolTime       Int      @default(0)
  // meta
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model UserRankHistory {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  pt        Int       @default(0)
  earnedPt  Int       @default(0)
  matchId   Int
  matchDate MatchDate @relation(fields: [matchId], references: [id])
  // meta
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id                String            @id
  userName          String
  banned            Boolean           @default(false)
  userRankStatuses  UserRankStatus?
  userRankHistories UserRankHistory[]
  records           Record[]
  userSettings      UserSettings?
  // meta
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model UserSettings {
  id                     String   @id
  user                   User     @relation(fields: [id], references: [id])
  showRank               Boolean  @default(true)
  showLeaderboardRank    Boolean  @default(true)
  showLeaderboardRanking Boolean  @default(true)
  showProfileStats       Boolean  @default(true)
  showProfileSearch      Boolean  @default(true)
  // meta
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
